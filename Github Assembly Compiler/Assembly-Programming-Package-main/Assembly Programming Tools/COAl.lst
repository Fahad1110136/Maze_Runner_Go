   725                                  kbisr:                                      ; key board interrupt service routine
   726 000015AE 50                      push ax
   727 000015AF 06                      push es
   728 000015B0 57                      push di
   729 000015B1 56                      push si  
   730 000015B2 E460                    in al,0x60                                  ; reads a char from the key board
   731 000015B4 3C48                    cmp al,0x48                                 ; scan code of up arrow key
   732 000015B6 740E                    je moveup
   733 000015B8 3C50                    cmp al,0x50                                 ; scan code of down arrow key
   734 000015BA 7415                    je movedown
   735 000015BC 3C4B                    cmp al,0x4B                                 ; scan code of left arrow key
   736 000015BE 741C                    je moveleft
   737 000015C0 3C4D                    cmp al,0x4D                                 ; scan code of right arrow key
   738 000015C2 7423                    je moveright
   739 000015C4 EB2A                    jmp exitkbisr                               ; no such arrow press exit interrupt routine
   740                                  moveup:
   741 000015C6 A1[B200]                mov ax,[currentposition]
   742 000015C9 2DA000                  sub ax,160                                  ; move up one row
   743 000015CC E82A00                  call checkcollision
   744 000015CF EB1F                    jmp exitkbisr
   745                                  movedown:
   746 000015D1 A1[B200]                mov ax,[currentposition]
   747 000015D4 05A000                  add ax,160                                  ; move down one row
   748 000015D7 E81F00                  call checkcollision
   749 000015DA EB14                    jmp exitkbisr    
   750                                  moveleft:
   751 000015DC A1[B200]                mov ax,[currentposition]
   752 000015DF 83E802                  sub ax,2                                    ; move left one column
   753 000015E2 E81400                  call checkcollision
   754 000015E5 EB09                    jmp exitkbisr    
   755                                  moveright:
   756 000015E7 A1[B200]                mov ax,[currentposition]
   757 000015EA 83C002                  add ax,2                                    ; move right one column
   758 000015ED E80900                  call checkcollision    
   759                                  exitkbisr:
   760 000015F0 B020                    mov al,0x20
   761 000015F2 E620                    out 0x20,al                                 ; end of interrupt
   762 000015F4 5E                      pop si
   763 000015F5 5F                      pop di
   764 000015F6 07                      pop es
   765 000015F7 58                      pop ax
   766 000015F8 CF                      iret
   767                                  checkcollision:                             ; collision detection
   768 000015F9 55                      push bp
   769 000015FA 89E5                    mov bp,sp
   770 000015FC 53                      push bx
   771 000015FD 52                      push dx    
   772 000015FE 89C3                    mov bx,ax                                   ; store target position
   773 00001600 83FB00                  cmp bx, 0                                   ; top boundary (after first row)
   774 00001603 7C29                    jl boundaryfail                             ; basic boundary check for maze (normal conditions)                   
   775 00001605 81FB200D                cmp bx, 3360                                ; bottom boundary (before last row)
   776 00001609 7F23                    jg boundaryfail
   777 0000160B B800B8                  mov ax,0xB800
   778 0000160E 8EC0                    mov es,ax
   779 00001610 268B17                  mov dx,[es:bx]                              ; get character at target position
   780 00001613 80FA45                  cmp dl,'E'                                  ; check end label first
   781 00001616 746A                    je gamewon
   782 00001618 80FE44                  cmp dh,0x44                                 ; check wall character attribute
   783 0000161B 7413                    je checkifsuperman
   784 0000161D 80FA0C                  cmp dl,0x0C                                 ; check to activate superman power up
   785 00001620 7431                    je activatesuperman
   786 00001622 80FA03                  cmp dl,0x03                                 ; check to add points (heart)
   787 00001625 7439                    je collectpoints    
   788 00001627 80FA15                  cmp dl,0x15                                 ; check to hit enemy: remove points
   789 0000162A 7444                    je hitenemy
   790 0000162C EB0B                    jmp updateposition
   791                                  boundaryfail:
